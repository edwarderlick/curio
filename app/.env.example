# Shelbynet — the only fully-operational Shelby network today (testnet is
# listed "TBD" in Shelby's own docs). Values below match what `shelby init`
# writes to ~/.shelby/config.yaml under contexts.shelbynet.
VITE_SHELBY_NETWORK=shelbynet
VITE_SHELBY_RPC_ENDPOINT=https://api.shelbynet.shelby.xyz/shelby
VITE_APTOS_FULLNODE=https://api.shelbynet.shelby.xyz/v1
VITE_APTOS_INDEXER=https://api.shelbynet.shelby.xyz/v1/graphql

# Optional: self-serve key from geomi.dev raises rate limits above the
# anonymous tier. Leave blank to run anonymous.
VITE_SHELBY_API_KEY=

# v2 catalog index lives in this same project now (api/catalog/*, Vercel
# serverless functions), so /api is same-origin — leave this blank.
VITE_API_BASE_URL=

# --- Server-side only (used by api/*.ts, NOT exposed to the client — no
# VITE_ prefix) ---

# Postgres connection string for the catalog index. Add a Neon database via
# the Vercel project's Storage tab and it sets this (or POSTGRES_URL)
# automatically; only needed by hand for local `vercel dev`.
DATABASE_URL=

# Used by api/catalog/unlock-grants to verify a claimed payment tx really
# happened on-chain before granting access. Same values as above.
APTOS_FULLNODE=https://api.shelbynet.shelby.xyz/v1
SOLANA_RPC_ENDPOINT=
