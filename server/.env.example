# v1 off-chain index server
PORT=8787

# Comma-separated allowed origins for CORS, e.g. https://curio.example.com.
# Leave blank in dev (wide open, matches Vite's proxy setup). Set this in
# production — an open CORS policy on a server with real payment/deletion
# endpoints is not safe for a public deployment.
CORS_ORIGIN=

# Shelbynet endpoints (same values as ~/.shelby/config.yaml contexts.shelbynet)
SHELBY_NETWORK=shelbynet
SHELBY_RPC_ENDPOINT=https://api.shelbynet.shelby.xyz/shelby
APTOS_FULLNODE=https://api.shelbynet.shelby.xyz/v1
APTOS_INDEXER=https://api.shelbynet.shelby.xyz/v1/graphql
SHELBY_API_KEY=

# Optional: Solana RPC used to verify unlock-grant payment transactions.
# Defaults to the public Devnet cluster URL if unset.
SOLANA_RPC_ENDPOINT=

# Signing account for the transcode/upload pipeline (Step 7). Intentionally
# NOT a private key here — the server shells out to / imports the Shelby CLI
# config at ~/.shelby/config.yaml and references this account by name, so a
# raw key never lives in a project file.
SHELBY_CLI_ACCOUNT_NAME=dev
